import gameOfThrone.*

test "agarra artefactos" {
	
	carlos.agarra(espada)
	carlos.agarra(libro)
	carlos.agarra(collar)

	assert.equals( #{espada, libro}, carlos.artefactos() )
	
}

test "casa" {

	carlos.agarra(espada)
	carlos.agarra(libro)
	carlos.ir()
 	carlos.agarra(collar)
 	carlos.ir()
 	
 	assert.that(carlos.artefactos().isEmpty())
 	assert.equals(#{espada,libro,collar}, casa.artefactos())
 	
}

test "posesiones" {
	
	casa.agregarArtefactos(#{collar, espada})
	
	carlos.agarra(armadura)
	assert.equals(#{collar, armadura, espada}, carlos.posesiones())
	assert.that(carlos.posee(armadura))
	assert.notThat(carlos.posee(libro))
	
}

test "historia" {
	carlos.agarra(espada)
	carlos.agarra(libro)
	carlos.agarra(collar)
	carlos.ir()
	carlos.agarra(armadura)
	carlos.agarra(collar)

  assert.equals([espada, libro, collar, armadura, collar], carlos.historia())	
}
